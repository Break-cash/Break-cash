{
  "name": "break-cash-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "railway:check-uploads": "node server/scripts/check-railway-upload-env.js",
    "wallet:integrity": "node server/scripts/wallet-integrity-check.js",
    "dev:all": "node server/index.js",
    "build": "tsc -b && vite build",
    "cap:sync": "npx cap sync android",
    "cap:copy": "npx cap copy android",
    "android:add": "npx cap add android",
    "android:open": "npx cap open android",
    "android:build": "npm run build && npm run cap:sync",
    "android:release": "powershell -ExecutionPolicy Bypass -File scripts/build-android-release.ps1",
    "cap:sync:ios": "npx cap sync ios",
    "cap:copy:ios": "npx cap copy ios",
    "ios:add": "npx cap add ios",
    "ios:open": "npx cap open ios",
    "ios:build": "npm run build && npm run cap:sync:ios",
    "ios:handoff": "powershell -ExecutionPolicy Bypass -File scripts/package-ios-handoff.ps1",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node server/index.js",
    "start:prod": "npm run build && node server/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.940.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/push-notifications": "^8.0.3",
    "@sentry/node": "^10.43.0",
    "@sentry/react": "^10.43.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.37.0",
    "jsonwebtoken": "^9.0.3",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.577.0",
    "multer": "^2.1.1",
    "mysql2": "^3.19.1",
    "nodemailer": "^8.0.2",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "sqlite3": "^5.1.7",
    "twilio": "^5.12.2",
    "web-push": "^3.6.7",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
