PORT=5174
NODE_ENV=development

# Optional: absolute path for uploaded files on a persistent volume (Render Disk, VPS mount, etc.).
# Example on Render: create a Disk, mount it at /var/data, then set:
# UPLOADS_ROOT=/var/data/uploads
# Subfolders (avatars, kyc, support, …) are created automatically under this path.
# UPLOADS_ROOT=

# Optional: S3-compatible bucket (Cloudflare R2, AWS S3, MinIO). When set, new uploads go to the bucket;
# /uploads/... redirects to the public URL. Pairs well with Railway (UPLOADS_ROOT=/tmp) without a volume.
# OBJECT_STORAGE_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# OBJECT_STORAGE_REGION=auto
# OBJECT_STORAGE_BUCKET=your-bucket
# OBJECT_STORAGE_ACCESS_KEY=
# OBJECT_STORAGE_SECRET_KEY=
# OBJECT_STORAGE_PUBLIC_URL=https://pub-xxxxx.r2.dev
# OBJECT_STORAGE_FORCE_PATH_STYLE=0

# PostgreSQL connection string (use Railway public URL locally)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Set to false only when connecting to trusted internal DB hosts
PGSSL=true

# Auth and base accounts
JWT_SECRET=change_me_to_a_strong_secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=StrongAdminPassword123!
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=StrongOwnerPassword123!
DEFAULT_WALLET_LINK=https://wallet.example.com

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SMTP Email (optional, for email password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Sentry (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Uptime monitor optional tokenized probe URL support
UPTIME_PING_TOKEN=

# Development-only: expose verification/reset codes in API responses when mock providers are used.
# Keep this OFF in production.
ALLOW_DEV_CODE=0
