PORT=5174
NODE_ENV=development

# PostgreSQL connection string (use Railway public URL locally)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Set to false only when connecting to trusted internal DB hosts
PGSSL=true

# Auth and base accounts
JWT_SECRET=change_me_to_a_strong_secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=StrongAdminPassword123!
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=StrongOwnerPassword123!
DEFAULT_WALLET_LINK=https://wallet.example.com

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SMTP Email (optional, for email password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Sentry (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Firebase FCM native push (required for Android/iOS app notifications)
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Uptime monitor optional tokenized probe URL support
UPTIME_PING_TOKEN=

# Development-only: expose verification/reset codes in API responses when mock providers are used.
# Keep this OFF in production.
ALLOW_DEV_CODE=0
