{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "www.breakcash.cash" }
      ],
      "destination": "https://breakcash.cash/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://break-cash.up.railway.app/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://break-cash.up.railway.app/uploads/:path*"
    },
    {
      "source": "/((?!api/|uploads/|assets/).*)",
      "destination": "/index.html"
    }
  ]
}
