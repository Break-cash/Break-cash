{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.breakcash.cash/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://api.breakcash.cash/uploads/:path*"
    },
    {
      "source": "/((?!api/|uploads/|assets/).*)",
      "destination": "/index.html"
    }
  ]
}
